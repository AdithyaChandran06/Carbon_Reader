# ─── Server ───────────────────────────────────────────────────────────────────
PORT=

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ─── Frontend CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=

# ─── ML Microservice (Python FastAPI on port 8001) ───────────────────────────
ML_SERVICE_URL=
ML_TIMEOUT_MS=

# ─── Live Emission Factor APIs ────────────────────────────────────────────────
# Climatiq - best for activity-based factors
# Sign up: https://www.climatiq.io
CLIMATIQ_API_KEY=
# Carbon Interface - electricity-focused
# Sign up: https://www.carboninterface.com
CARBON_INTERFACE_API_KEY=

# Electricity Maps - real-time grid carbon intensity
# Sign up: https://www.electricitymaps.com
ELECTRICITY_MAPS_API_KEY=

# CO2Signal - free alternative for grid intensity (uses Electricity Maps data)
# Sign up: https://www.co2signal.com (free, just email signup)
CO2SIGNAL_API_KEY=
